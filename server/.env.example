PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/emi_management
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-this-refresh-secret-at-least-32-chars
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
CLIENT_URL=http://localhost:5173
APP_TIMEZONE=Asia/Dhaka
EMAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_APP_PASSWORD=your-16-character-google-app-password
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
RESEND_API_KEY=
EMAIL_FROM=FinanceLend <your-gmail-address@gmail.com>
DEMO_EMAIL_RECIPIENT=your-demo-recipient@gmail.com
EMAIL_RELAY_URL=
EMAIL_RELAY_SECRET=
EXPOSE_EMAIL_OTP=false
UPLOAD_DIR=uploads
SEED_ADMIN_EMAIL=admin@emi.local
SEED_ADMIN_PASSWORD=Admin@123
AUTO_SEED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=bdt
STRIPE_BDT_PER_USD=120
ALLOW_STRIPE_CURRENCY_CONVERSION=false
ALLOW_STRIPE_RETURN_CONFIRM=true
USE_MEMORY_DB=false
NODE_ENV=development
# Identity cross-validation (FastAPI locally or Hugging Face Space)
PUBLIC_CLIENT_URL=http://localhost:5173
IDENTITY_AI_URL=http://localhost:8001
# Use localhost for native Python, host.docker.internal when FastAPI runs in Docker.
IDENTITY_PUBLIC_API_URL=http://host.docker.internal:5000
IDENTITY_AI_SERVICE_KEY=replace-with-at-least-32-random-characters
# Generate with: openssl rand -base64 32
IDENTITY_DATA_ENCRYPTION_KEY=
IDENTITY_SESSION_TTL_MINUTES=10
IDENTITY_ARTIFACT_RETENTION_HOURS=24
IDENTITY_AI_TIMEOUT_MS=180000
IDENTITY_NAME_MATCH_THRESHOLD=0.90
IDENTITY_NAME_BORDERLINE_THRESHOLD=0.78
IDENTITY_FACE_MATCH_THRESHOLD=0.363
IDENTITY_FACE_BORDERLINE_THRESHOLD=0.30
IDENTITY_LIVENESS_ENABLED=true
